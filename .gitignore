# MetaLens Git Ignore

# Compiled binary / build output
/target/

# Cargo specific
**/*.rs.bk
# Cargo.lock is tracked for binary projects
# Cargo.lock

# Windows development files
*.pdb
*.obj
*.lib
*.exp
*.def
*.ilk
*.suo
*.user
*.aps

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# ExifTool payload / local dev
assets/exiftool.exe
assets/exiftool(-k).exe
assets/exiftool_files/
exiftool_tmp/

# Log files
*.log
