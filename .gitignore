# MetaLens — Git Exclusion Rules

# --- RUST / CARGO ---
/target/
Cargo.lock
**/*.rs.bk
debug/
release/

# --- OS SPECIFIC ---
# Windows
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
*.icloud

# Linux
*~
.fuse_hidden*
.directory
.trash/
.nfs*

# --- IDEs / EDITORS ---
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains
.idea/
*.iws
out/

# Vim
[._]*.s[a-v][a-z]
! [._]*.svg
[._]sw[a-p]
[._]sba
[._]sbc
[._]st[a-z]
*.un~
Session.vim
.netrwhist

# --- ASSETS & PAYLOADS ---
# Local dev tools (Bundled in release)
assets/exiftool.exe
assets/exiftool(-k).exe
assets/exiftool_files/
exiftool_tmp/
/temp_meta/

# --- LOGS & MISC ---
*.log
*.tmp
*.bak
*.old
node_modules/
.env
.env.local

